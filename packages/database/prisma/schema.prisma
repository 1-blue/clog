generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 공통 Enums
// ============================================

/// OAuth 제공자
enum Provider {
  KAKAO  /// 카카오
  GOOGLE /// 구글
}

/// 유저 권한
enum Role {
  ADMIN   /// 관리자 페이지 접근 권한
  MANAGER /// 정보 수정/삭제 권한
  GUEST   /// 일반 유저 (기본값)
}

/// 지역 (17개 시도)
enum Region {
  SEOUL     /// 서울
  GYEONGGI  /// 경기
  INCHEON   /// 인천
  BUSAN     /// 부산
  DAEGU     /// 대구
  DAEJEON   /// 대전
  GWANGJU   /// 광주
  ULSAN     /// 울산
  SEJONG    /// 세종
  GANGWON   /// 강원
  CHUNGBUK  /// 충북
  CHUNGNAM  /// 충남
  JEONBUK   /// 전북
  JEONNAM   /// 전남
  GYEONGBUK /// 경북
  GYEONGNAM /// 경남
  JEJU      /// 제주
}

/// 난이도
enum Difficulty {
  V0     /// V0
  V1     /// V1
  V2     /// V2
  V3     /// V3
  V4     /// V4
  V5     /// V5
  V6     /// V6
  V7     /// V7
  V8     /// V8
  V9     /// V9
  V10    /// V10
}

// ============================================
// 암장 Enums
// ============================================

/// 영업시간 요일 타입
enum DayType {
  MON     /// 월요일
  TUE     /// 화요일
  WED     /// 수요일
  THU     /// 목요일
  FRI     /// 금요일
  SAT     /// 토요일
  SUN     /// 일요일
}

/// 암장 시설 타입
enum GymFacilityType {
  PARKING   /// 주차장
  SHOWER    /// 샤워실
  LOCKER    /// 락커
  REST_AREA /// 휴식 공간
  TRAINING  /// 트레이닝 시설
}

/// 암장 리뷰 특징
enum GymReviewFeature {
  COOL_AIR       /// 쾌적한 냉방
  WIDE_STRETCH   /// 넓은 스트레칭존
  VARIOUS_LEVEL  /// 다양한 난이도
  KIND_STAFF     /// 친절한 스태프
  EASY_PARKING   /// 주차 편리
  SHOWER_ROOM    /// 샤워실 완비
  CLEAN_FACILITY /// 깨끗한 시설
  GOOD_VENT      /// 환기 좋음
}

/// 체감 난이도
enum GymPerceivedDifficulty {
  EASY   /// 쉬움
  NORMAL /// 보통
  HARD   /// 어려움
}

// ============================================
// 클라이밍 Enums
// ============================================

/// 시도 결과
enum ClimbingAttemptResult {
  SEND    /// 완등
  ATTEMPT /// 시도
  FLASH   /// 플래시 (첫 시도 완등)
  ONSIGHT /// 온사이트 (정보 없이 첫 시도 완등)
}

// ============================================
// 커뮤니티 Enums
// ============================================

/// 게시글 카테고리
enum PostCategory {
  FREE   /// 자유
  TIPS   /// 팁/노하우
  REVIEW /// 후기
  MEETUP /// 모임
  GEAR   /// 장비
}

/// 알림 타입
enum NotificationType {
  COMMENT    /// 댓글
  LIKE       /// 좋아요
  FOLLOW     /// 팔로우
  SYSTEM     /// 시스템
  GYM_UPDATE /// 암장 업데이트
}

// ============================================
// 유저
// ============================================

/// 유저
model User {
  /// 유저 고유 ID
  id            String      @id @default(uuid()) @db.Uuid
  /// 이메일
  email         String      @unique
  /// 닉네임
  nickname      String
  /// 자기소개
  bio           String?
  /// 프로필 이미지 URL
  profileImage  String?     @map("profile_image")
  /// 커버 이미지 URL
  coverImage    String?     @map("cover_image")
  /// 인스타그램 아이디
  instagramId   String?     @map("instagram_id")
  /// 유튜브 URL
  youtubeUrl    String?     @map("youtube_url")
  /// 최고 난이도
  maxDifficulty Difficulty? @map("max_difficulty")
  /// 홈짐 ID
  homeGymId     String?     @map("home_gym_id") @db.Uuid
  /// 유저 권한
  role          Role        @default(GUEST)
  /// 체크인 후 자동 체크아웃까지 시간(분). 기본 240(4시간)
  checkInAutoDurationMinutes Int @default(240) @map("check_in_auto_duration_minutes")
  /// 생성일
  createdAt     DateTime    @default(now()) @map("created_at")
  /// 수정일
  updatedAt     DateTime    @updatedAt @map("updated_at")

  /// 홈짐
  homeGym       Gym?              @relation("homeGym", fields: [homeGymId], references: [id], onDelete: SetNull)
  /// OAuth 계정 목록
  accounts      Account[]
  /// 클라이밍 세션 목록
  sessions      ClimbingSession[]
  /// 암장 리뷰 목록
  reviews       GymReview[]
  /// 게시글 목록
  posts         Post[]
  /// 댓글 목록
  comments      PostComment[]
  /// 알림 목록
  notifications Notification[]
  /// 게시글 좋아요 목록
  postLikes     PostLike[]
  /// 게시글 북마크 목록
  postBookmarks PostBookmark[]
  /// 팔로잉 목록
  following     Follow[]          @relation("follower")
  /// 팔로워 목록
  followers     Follow[]          @relation("following")
  /// 암장 체크인 기록
  gymCheckIns   GymCheckIn[]
  /// 암장 북마크 목록
  gymBookmarks  GymBookmark[]
  /// API 라우트 예외 로그 (발생 시 유저)
  apiErrorLogs  ApiErrorLog[]

  @@map("users")
}

/// API Route Handler에서 catch된 오류 로그
model ApiErrorLog {
  /// 로그 ID
  id            String   @id @default(uuid()) @db.Uuid
  /// 발생 시각
  createdAt     DateTime @default(now()) @map("created_at")
  /// HTTP 메서드
  method        String
  /// URL pathname (쿼리 제외)
  path          String
  /// method + path 요약
  endpoint      String
  /// 메시지·스택 등 상세
  errorLog      String   @map("error_log") @db.Text
  /// 로그인 유저 ID (비로그인 null)
  userId        String?  @map("user_id") @db.Uuid
  /// 클라이언트에 반환한 HTTP 상태
  httpStatus    Int?     @map("http_status")
  /// 클라이언트 토스트 문구
  clientMessage String?  @map("client_message")
  /// Error.name 등
  errorName     String?  @map("error_name")
  /// x-trace-id / x-request-id 또는 생성 UUID
  traceId       String?  @map("trace_id")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@map("api_error_logs")
}

/// OAuth 계정
model Account {
  /// 계정 고유 ID
  id                String   @id @default(uuid()) @db.Uuid
  /// 유저 ID
  userId            String   @map("user_id") @db.Uuid
  /// OAuth 제공자
  provider          Provider
  /// 제공자 계정 ID
  providerAccountId String   @map("provider_account_id")
  /// 액세스 토큰
  accessToken       String?  @map("access_token")
  /// 리프레시 토큰
  refreshToken      String?  @map("refresh_token")
  /// 토큰 만료일
  expiresAt         Int?     @map("expires_at")
  /// 생성일
  createdAt         DateTime @default(now()) @map("created_at")

  /// 유저
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

/// 팔로우 관계
model Follow {
  /// 팔로우 고유 ID
  id          String   @id @default(uuid()) @db.Uuid
  /// 팔로우하는 유저 ID
  followerId  String   @map("follower_id") @db.Uuid
  /// 팔로우 대상 유저 ID
  followingId String   @map("following_id") @db.Uuid
  /// 생성일
  createdAt   DateTime @default(now()) @map("created_at")

  /// 팔로우하는 유저
  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  /// 팔로우 대상 유저
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

// ============================================
// 암장
// ============================================

/// 암장
model Gym {
  /// 암장 고유 ID
  id              String   @id @default(uuid()) @db.Uuid
  /// 암장 이름
  name            String
  /// 주소
  address         String
  /// 지역
  region          Region
  /// 전화번호
  phone           String
  /// 영업시간 공지 (예: "명절 당일 휴무")
  notice          String?

  /// 현재 혼잡도 (0~100)
  congestion      Int      @default(0)
  /// 현재 추정 이용 인원 (실시간 표시용)
  visitorCount    Int      @default(0) @map("visitor_count")
  /// 수용 인원 (혼잡도 카드 분모)
  visitorCapacity Int      @default(60) @map("visitor_capacity")
  /// 위도
  latitude        Float
  /// 경도
  longitude       Float
  /// 설명
  description     String
  /// 웹사이트 URL
  website         String?
  /// 썸네일 이미지 URL
  thumbnailUrl    String?  @map("thumbnail_url")
  /// 인스타그램 아이디
  instagramId     String?  @map("instagram_id")
  /// 가격 정보 (JSON: { daily: number, monthly: number, ... })
  priceInfo       Json?    @map("price_info")
  /// 평균 평점
  avgRating       Float    @default(0) @map("avg_rating")
  /// 리뷰 수
  reviewCount     Int      @default(0) @map("review_count")
  /// 생성일
  createdAt       DateTime @default(now()) @map("created_at")
  /// 수정일
  updatedAt       DateTime @updatedAt @map("updated_at")

  /// 홈짐으로 등록한 유저 목록
  homeGymUsers     User[]               @relation("homeGym")
  /// 시설 목록
  facilities       GymFacilityType[]  @default([])
  /// 영업시간 목록
  openHours        GymOpenHour[]
  /// 이미지 목록
  images           GymImage[]
  /// 난이도 색상 매핑
  difficultyColors GymDifficultyColor[]
  /// 암장 북마크 목록
  bookmarks        GymBookmark[]
  /// 세팅 일정
  settingSchedule  GymSettingSchedule?
  /// 클라이밍 세션 목록
  sessions         ClimbingSession[]
  /// 리뷰 목록
  reviews          GymReview[]
  /// 체크인 세션
  checkIns         GymCheckIn[]

  @@map("gyms")
}

/// 암장 체크인 (자동 체크아웃: endsAt 경과 시 비활성)
model GymCheckIn {
  /// 체크인 고유 ID
  id        String    @id @default(uuid()) @db.Uuid
  /// 유저 ID
  userId    String    @map("user_id") @db.Uuid
  /// 암장 ID
  gymId     String    @map("gym_id") @db.Uuid
  /// 체크인 시각
  startedAt DateTime  @default(now()) @map("started_at")
  /// 자동 체크아웃 예정 시각
  endsAt    DateTime  @map("ends_at")
  /// 수동 체크아웃 또는 정리 시각 (null이면 아직 활성 후보)
  endedAt   DateTime? @map("ended_at")

  /// 유저
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 암장
  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId, endedAt, endsAt])
  @@index([userId, endedAt, endsAt])
  @@map("gym_check_ins")
}

/// 암장 이미지
model GymImage {
  /// 이미지 고유 ID
  id        String   @id @default(uuid()) @db.Uuid
  /// 암장 ID
  gymId     String   @map("gym_id") @db.Uuid
  /// 이미지 URL
  url       String
  /// 순서
  order     Int      @default(0)
  /// 생성일
  createdAt DateTime @default(now()) @map("created_at")

  /// 암장
  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@map("gym_images")
}

/// 암장 영업시간
model GymOpenHour {
  /// 고유 ID
  id      String  @id @default(uuid()) @db.Uuid
  /// 암장 ID
  gymId   String  @map("gym_id") @db.Uuid
  /// 요일
  dayType DayType @map("day_type")
  /// 오픈 시간 "HH:mm"
  open    String
  /// 마감 시간 "HH:mm"
  close   String

  /// 암장
  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([gymId, dayType])
  @@map("gym_open_hours")
}

/// 암장별 난이도 색상 매핑
model GymDifficultyColor {
  /// 고유 ID
  id         String     @id @default(uuid()) @db.Uuid
  /// 암장 ID
  gymId      String     @map("gym_id") @db.Uuid
  /// 난이도
  difficulty Difficulty
  /// HEX 색상 코드 (예: "#E05555")
  color      String
  /// 암장 자체 명칭 (예: "빨강", "레드")
  label      String
  /// 표시 순서
  order      Int        @default(0)

  /// 암장
  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([gymId, difficulty])
  @@map("gym_difficulty_colors")
}

/// 즐겨찾는 암장
model GymBookmark {
  /// 고유 ID
  id        String   @id @default(uuid()) @db.Uuid
  /// 유저 ID
  userId    String   @map("user_id") @db.Uuid
  /// 암장 ID
  gymId     String   @map("gym_id") @db.Uuid
  /// 생성일
  createdAt DateTime @default(now()) @map("created_at")

  /// 유저
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 암장
  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([userId, gymId])
  @@map("gym_bookmarks")
}

/// 암장 세팅 일정
model GymSettingSchedule {
  /// 고유 ID
  id              String    @id @default(uuid()) @db.Uuid
  /// 암장 ID
  gymId           String    @unique @map("gym_id") @db.Uuid
  /// 세팅 주기 (일 단위, 예: 14 = 2주)
  intervalDays    Int?      @map("interval_days")
  /// 마지막 세팅일
  lastSettingDate DateTime? @map("last_setting_date") @db.Date
  /// 다음 세팅 예정일
  nextSettingDate DateTime? @map("next_setting_date") @db.Date
  /// 세팅 관련 메모 (예: "매월 첫째 주 월요일")
  memo            String?
  /// 생성일
  createdAt       DateTime  @default(now()) @map("created_at")
  /// 수정일
  updatedAt       DateTime  @updatedAt @map("updated_at")

  /// 암장
  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@map("gym_setting_schedules")
}

/// 암장 리뷰
model GymReview {
  /// 리뷰 고유 ID
  id                  String                @id @default(uuid()) @db.Uuid
  /// 유저 ID
  userId              String                @map("user_id") @db.Uuid
  /// 암장 ID
  gymId               String                @map("gym_id") @db.Uuid
  /// 평점 (1~5)
  rating              Int
  /// 리뷰 내용
  content             String
  /// 체감 난이도
  perceivedDifficulty GymPerceivedDifficulty? @map("perceived_difficulty")
  /// 리뷰 특징 (enum 배열)
  features            GymReviewFeature[]    @default([])
  /// 생성일
  createdAt           DateTime              @default(now()) @map("created_at")
  /// 수정일
  updatedAt           DateTime              @updatedAt @map("updated_at")

  /// 유저
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 암장
  gym    Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  /// 이미지 URL 목록
  imageUrls           String[]              @default([]) @map("image_urls")

  @@unique([userId, gymId])
  @@map("reviews")
}

// ============================================
// 클라이밍
// ============================================

/// 클라이밍 세션
model ClimbingSession {
  /// 세션 고유 ID
  id        String    @id @default(uuid()) @db.Uuid
  /// 유저 ID
  userId    String    @map("user_id") @db.Uuid
  /// 암장 ID
  gymId     String    @map("gym_id") @db.Uuid
  /// 세션 날짜
  date      DateTime  @db.Date
  /// 시작 시간
  startTime DateTime? @map("start_time")
  /// 종료 시간
  endTime   DateTime? @map("end_time")
  /// 메모
  memo      String?
  /// 공개 여부
  isPublic  Boolean   @default(true) @map("is_public")
  /// 생성일
  createdAt DateTime  @default(now()) @map("created_at")
  /// 수정일
  updatedAt DateTime  @updatedAt @map("updated_at")

  /// 유저
  user   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 암장
  gym    Gym                   @relation(fields: [gymId], references: [id], onDelete: Cascade)
  /// 루트 목록
  routes    ClimbingRoute[]
  /// 세션 이미지 URL 목록
  imageUrls String[]            @default([]) @map("image_urls")

  @@map("climbing_sessions")
}

/// 클라이밍 루트 기록
model ClimbingRoute {
  /// 루트 고유 ID
  id                  String                 @id @default(uuid()) @db.Uuid
  /// 세션 ID
  sessionId           String                 @map("session_id") @db.Uuid
  /// 난이도
  difficulty          Difficulty
  /// 시도 결과
  result              ClimbingAttemptResult
  /// 시도 횟수
  attempts            Int                    @default(1)
  /// 체감 난이도
  perceivedDifficulty GymPerceivedDifficulty? @map("perceived_difficulty")
  /// 메모
  memo                String?
  /// 순서
  order               Int                    @default(0)
  /// 생성일
  createdAt           DateTime               @default(now()) @map("created_at")

  /// 세션
  session ClimbingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("routes")
}

// ============================================
// 커뮤니티
// ============================================

/// 커뮤니티 게시글
model Post {
  /// 게시글 고유 ID
  id           String       @id @default(uuid()) @db.Uuid
  /// 작성자 ID
  authorId     String       @map("author_id") @db.Uuid
  /// 카테고리
  category     PostCategory
  /// 제목
  title        String
  /// 본문
  content      String
  /// 조회수
  viewCount    Int          @default(0) @map("view_count")
  /// 좋아요 수
  likeCount    Int          @default(0) @map("like_count")
  /// 댓글 수
  commentCount Int          @default(0) @map("comment_count")
  /// 생성일
  createdAt    DateTime     @default(now()) @map("created_at")
  /// 수정일
  updatedAt    DateTime     @updatedAt @map("updated_at")

  /// 이미지 URL 목록
  imageUrls    String[]     @default([]) @map("image_urls")
  /// 태그 목록
  tags         String[]     @default([])

  /// 작성자
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  /// 좋아요 목록
  likes     PostLike[]
  /// 북마크 목록
  bookmarks PostBookmark[]
  /// 댓글 목록
  comments  PostComment[]

  @@map("posts")
}

/// 게시글 좋아요
model PostLike {
  /// 좋아요 고유 ID
  id        String   @id @default(uuid()) @db.Uuid
  /// 게시글 ID
  postId    String   @map("post_id") @db.Uuid
  /// 유저 ID
  userId    String   @map("user_id") @db.Uuid
  /// 생성일
  createdAt DateTime @default(now()) @map("created_at")

  /// 게시글
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// 유저
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_likes")
}

/// 게시글 북마크
model PostBookmark {
  /// 북마크 고유 ID
  id        String   @id @default(uuid()) @db.Uuid
  /// 게시글 ID
  postId    String   @map("post_id") @db.Uuid
  /// 유저 ID
  userId    String   @map("user_id") @db.Uuid
  /// 생성일
  createdAt DateTime @default(now()) @map("created_at")

  /// 게시글
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// 유저
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_bookmarks")
}

/// 게시글 댓글
model PostComment {
  /// 댓글 고유 ID
  id        String   @id @default(uuid()) @db.Uuid
  /// 게시글 ID
  postId    String   @map("post_id") @db.Uuid
  /// 작성자 ID
  authorId  String   @map("author_id") @db.Uuid
  /// 부모 댓글 ID (대댓글)
  parentId  String?  @map("parent_id") @db.Uuid
  /// 댓글 내용
  content   String
  /// 생성일
  createdAt DateTime @default(now()) @map("created_at")
  /// 수정일
  updatedAt DateTime @updatedAt @map("updated_at")

  /// 게시글
  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// 작성자
  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  /// 부모 댓글
  parent  PostComment?  @relation("replies", fields: [parentId], references: [id], onDelete: Cascade)
  /// 대댓글 목록
  replies PostComment[] @relation("replies")

  @@map("comments")
}

// ============================================
// 알림
// ============================================

/// 알림
model Notification {
  /// 알림 고유 ID
  id        String           @id @default(uuid()) @db.Uuid
  /// 수신자 ID
  userId    String           @map("user_id") @db.Uuid
  /// 알림 타입
  type      NotificationType
  /// 알림 제목
  title     String
  /// 알림 내용
  message   String
  /// 읽음 여부
  isRead    Boolean          @default(false) @map("is_read")
  /// 관련 링크
  link      String?
  /// 생성일
  createdAt DateTime         @default(now()) @map("created_at")

  /// 수신자
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
