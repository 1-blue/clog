{
  "name": "@clog/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./prisma": "./dist/prisma.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed/index.ts",
    "db:seed:prod": "SEED_PROFILE=prod tsx prisma/seed/index.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clog/typescript-config": "workspace:*",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod-prisma-types": "^3.3.11"
  }
}
